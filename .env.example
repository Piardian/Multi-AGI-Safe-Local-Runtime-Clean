# Antigravity / Quant Lab environment variables
# Copy this file to .env and fill the values you need.

# Provider:
#   api        = API provider (currently Groq backend)
#   browser    = AI web UI through Chrome/Playwright bridge
#   local_tool = local tool executor only
# Legacy names groq and browser_gpt are still accepted.
LLM_PROVIDER=api
PLANNER_PROVIDER=api
CODER_PROVIDER=api
CRITIC_PROVIDER=api
CHAT_PROVIDER=api
ROUTER_PROVIDER=api
PROMPT_ARCHITECT_PROVIDER=api
LOCAL_AGENT_PROVIDER=api
WEB_QUERY_PROVIDER=browser
RESEARCH_PROVIDER=browser
DEFAULT_CHAT_PROVIDER=api
DEFAULT_RESEARCH_PROVIDER=browser
DEFAULT_CODING_PROVIDER=api
DEFAULT_AGENT_PROVIDER=api
DEFAULT_BROWSER_TARGET=chatgpt
ORCHESTRATOR_BRAIN_PROVIDER=browser
ORCHESTRATOR_BRAIN_TARGET=chatgpt
ORCHESTRATOR_BRAIN_FALLBACK_PROVIDER=api
ORCHESTRATOR_BRAIN_FALLBACK_MODEL=llama-3.1-8b-instant
ORCHESTRATOR_BRAIN_USE_LLM=true

# Optional local model provider
LOCAL_MODEL_PROVIDER=lmstudio
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
LOCAL_FAST_MODEL=Qwen3.5-4B-Q4_K_M
LOCAL_REASONER_MODEL=DeepSeek-R1-Distill-Llama-8B-Q4_K_M
USE_LOCAL_FAST=true
USE_LOCAL_CRITIC=true
USE_LOCAL_CODER=false
USE_LOCAL_ROUTER=false
LOCAL_MODEL_TIMEOUT_SECONDS=20
LOCAL_MODEL_MAX_TOKENS=800

# Groq
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_API_KEY_2=

# Browser GPT
BROWSER_GPT_URL=https://chatgpt.com
BROWSER_GPT_TIMEOUT=180
BROWSER_PROVIDER_TIMEOUT=180
BROWSER_PROVIDER_API_FALLBACK=false
CHAT_BROWSER_TARGET=chatgpt
RESEARCH_BROWSER_TARGET=perplexity
BROWSER_GPT_AUTO_START=true
BROWSER_GPT_CLOSE_AFTER=false
BROWSER_GPT_PROFILE_DIR=.browser-profile/chatgpt
CHROME_PATH=

# Models used when provider=groq
PM_MODEL=llama-3.3-70b-versatile
CODER_MODEL=llama-3.3-70b-versatile
CRITIC_MODEL=llama-3.3-70b-versatile
SECURITY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
CHAT_MODEL=llama-3.1-8b-instant
ROUTER_MODEL=llama-3.1-8b-instant
PROMPT_ARCHITECT_MODEL=llama-3.1-8b-instant
LOCAL_AGENT_MODEL=llama-3.1-8b-instant

# Direct questions/lists should print terminal answers instead of creating files.
DIRECT_ANSWER_MODE=true
ROUTER_USE_LLM=false

# Legacy PM mode used by orchestrator.py
PM_MODE=groq
CHROME_DEBUG_PORT=9222
BROWSER_TARGET=chatgpt

# PROJECT_ROOT=C:/Projeler/Trade_Bot

RATE_LIMIT_SLEEP=2.0
MAX_RETRIES=2
API_TIMEOUT=120
SUBPROCESS_TIMEOUT=300

# Official runtime safety. Keep DEV_MODE false for normal use.
DEV_MODE=false
AUDIT_LOG_FILE=logs/audit.jsonl
MAX_READ_FILE_CHARS=12000
MAX_WRITE_FILE_CHARS=200000
MAX_DIFF_LINES=240
MAX_LISTED_FILES=400
# Generated application code is not executed. This mode only parses a temporary copy.
SANDBOX_MODE=syntax_only
SANDBOX_TIMEOUT_SECONDS=20
DIAGNOSTIC_TIMEOUT_SECONDS=12
WEB_SEARCH_TIMEOUT_SECONDS=12
WEB_SEARCH_MAX_RESPONSE_BYTES=750000
# Legacy Quant worker is intentionally disabled in the normal runtime.
EXPERIMENTAL_QUANT_WORKER=false
# Do not send workspace file contents to an external API/browser model by default.
ALLOW_EXTERNAL_WORKSPACE_CONTENT=false

MAX_ITERATIONS=50
DRY_RUN=false
STOP_ON_TEST_FAILURE=true
ITERATION_COOLDOWN=5.0
LOG_LEVEL=INFO
